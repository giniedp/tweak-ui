{
  "name": "tweak-ui",
  "version": "0.8.0",
  "main": "dist/tweak-ui.umd.js",
  "module": "dist/tweak-ui.module.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/tweak-ui.module.js",
      "require": "./dist/tweak-ui.umd.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "author": "Alexander Gräfenstein",
  "license": "MIT",
  "type": "module",
  "description": "Tweak UI - a lightweight js library for building input controls with data binding",
  "scripts": {
    "dev": "concurrently -n ⬢,⬢ -c red,green,blue -p '{name}' -k 'pnpm:dev:lib' 'pnpm:dev:docs'",
    "dev:lib": "pnpm vite build -w",
    "dev:docs": "vitepress dev docs",
    "build": "pnpm build:vite && pnpm build:docs",
    "build:vite": "pnpm vite build",
    "build:api": "api-extractor run --local --verbose && api-documenter markdown -i temp -o docs/api",
    "build:docs": "vitepress build docs",
    "copy": "pnpm copy:scss",
    "copy:scss": "cp -R ./src/style ./dist/scss",
    "release": "pnpm run build && npm publish --access=public",
    "test": "karma start --single-run",
    "test:watch": "karma start --no-single-run --auto-watch",
    "test:coverage": "IS_COVERAGE=yes karma start --single-run"
  },
  "devDependencies": {
    "@microsoft/api-documenter": "^7.30.3",
    "@microsoft/api-extractor": "^7.58.5",
    "@types/mithril": "^2.2.8",
    "concurrently": "^9.2.1",
    "highlight.js": "^11.11.1",
    "tslib": "^2.1.0",
    "typescript": "^6.0.3",
    "vite": "8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "^1.6.4",
    "vitepress-sidebar": "^1.33.1",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "mithril": "^2.3.8"
  },
  "packageManager": "pnpm@9.1.2"
}
