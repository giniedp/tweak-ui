{
  "name": "tweak-ui",
  "version": "0.5.0",
  "main": "dist/tweak-ui.umd.js",
  "module": "dist/tweak-ui.module.js",
  "typings": "dist/lib/index.d.ts",
  "files": [
    "dist"
  ],
  "author": "Alexander Gräfenstein",
  "license": "MIT",
  "type": "module",
  "description": "Tweak UI - a lightweight js library for building input controls with data binding",
  "scripts": {
    "dev": "concurrently -n ⬢,⬢,⬢ -c red,green,blue -p '{name}' -k 'pnpm:dev:tsc' 'pnpm:dev:scss' 'pnpm:dev:docs'",
    "dev:tsc": "pnpm build:tsc -w",
    "dev:scss": "sass --watch src/style/index.scss dist/tweak-ui.css",
    "dev:docs": "vitepress dev docs",
    "build": "pnpm build:vite && pnpm build:tsc && pnpm build:scss && pnpm build:scss:min && pnpm build:docs",
    "build:vite": "pnpm vite build",
    "build:tsc": "pnpm tsc -p ./src/tsconfig.lib.json",
    "build:scss": "sass src/style/index.scss dist/tweak-ui.css",
    "build:scss:min": "sass src/style/index.scss dist/tweak-ui.min.css --style=compressed",
    "build:api": "api-extractor run --local --verbose && api-documenter markdown -i temp -o docs/api",
    "build:docs": "vitepress build docs",
    "copy": "pnpm copy:scss",
    "copy:scss": "cp -R ./src/style ./dist/scss",
    "release": "pnpm run build && npm publish --access=public",
    "test": "karma start --single-run",
    "test:watch": "karma start --no-single-run --auto-watch",
    "test:coverage": "IS_COVERAGE=yes karma start --single-run"
  },
  "devDependencies": {
    "@microsoft/api-documenter": "^7.12.12",
    "@microsoft/api-extractor": "^7.13.2",
    "@types/mithril": "^2.0.6",
    "concurrently": "^9.1.2",
    "highlight.js": "^11.11.1",
    "sass": "^1.32.8",
    "tslib": "^2.1.0",
    "tslint": "^6.1.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitepress": "^1.6.3",
    "vitepress-sidebar": "^1.31.1"
  },
  "dependencies": {
    "mithril": "^2.0.4"
  },
  "packageManager": "pnpm@9.1.2"
}
