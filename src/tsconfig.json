{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "../dist",
    "noImplicitAny": true,
    "noImplicitThis": true,
    "rootDir": ".",
    "sourceMap": true,
    "inlineSourceMap": false,
    "inlineSources": true,
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "target": "esnext",

    "allowSyntheticDefaultImports": true,
    "typeRoots": ["../node_modules/@types"]
  }
}
